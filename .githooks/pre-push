#!/bin/sh

# Block pushes whose destination is the protected main branch. This covers
# both local main and pushes from another branch via `git push origin HEAD:main`.
remote_name=$1
remote_url=$2

while IFS=' ' read -r local_ref local_oid remote_ref remote_oid; do
    case "$remote_ref" in
        refs/heads/main)
            echo "Direct pushes to 'main' are not allowed. Open a pull request instead." >&2
            exit 1
            ;;
    esac
done

exit 0
